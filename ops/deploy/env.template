# DSUSA Environment Configuration — F0 template
# Per Implementation Program §23: configuration is DATA, not code. No provider/model named in code (D27).
# Copy to .env per environment (dev/staging/prod); never commit real secrets.

# --- Database (per environment) ---
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/dsusa
# Application DB role whose UPDATE/DELETE on audit_entry is revoked (append-only enforcement).
DSUSA_APP_DB_ROLE=dsusa_app

# --- Service identities (mutual service auth; F0 auth substrate) ---
# Each platform service/registry/agent authenticates as a registered service identity.
# Secrets are injected per environment by the secret manager, not stored here.
DSUSA_SERVICE_ID=
DSUSA_SERVICE_SECRET_REF=

# --- Audit ---
# Audit class routing per action handled in component config (transactional vs informational).

# --- AI (vendor-neutral; OFF by default per D26/D28) ---
# No provider/model is named in code. These are runtime config only; left blank => AI disabled.
DSUSA_AI_ENABLED=false
DSUSA_AI_PROVIDER_KEY=
DSUSA_AI_MODEL_ID=

# --- Retention (durations are governance/legal input per D9; not set in code) ---
# Loaded into retention_policy via governance config before Retention cutover.

# --- Environment marker ---
DSUSA_ENV=dev
